<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.achievement.mapper.AchievementPlanRefMapper">

    <resultMap type="AchievementPlanRef" id="RefResult">
        <id property="id" column="id"/>
        <result property="achievementId" column="achievement_id"/>
        <result property="planId" column="plan_id"/>
    </resultMap>

    <insert id="batchInsert" parameterType="java.util.List">
        insert into achievement_plan_ref (achievement_id, plan_id, create_by, create_time)
        values
        <foreach collection="list" item="item" separator=",">
            (#{item.achievementId}, #{item.planId}, #{item.createBy}, sysdate())
        </foreach>
    </insert>

    <select id="selectByAchievementId" parameterType="Long" resultMap="RefResult">
        select * from achievement_plan_ref where achievement_id = #{achievementId}
    </select>

    <delete id="deleteByAchievementId" parameterType="Long">
        delete from achievement_plan_ref where achievement_id = #{achievementId}
    </delete>

</mapper>
