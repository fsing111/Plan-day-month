<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.plan.mapper.PlanRevisionMapper">

    <resultMap type="PlanRevision" id="PlanRevisionResult">
        <id     property="id"           column="id" />
        <result property="planId"       column="plan_id" />
        <result property="version"      column="version" />
        <result property="changes"      column="changes" />
        <result property="submitterNote" column="submitter_note" />
        <result property="createBy"     column="create_by" />
        <result property="createTime"   column="create_time" />
    </resultMap>

    <select id="selectPlanRevisionByPlanId" parameterType="Long" resultMap="PlanRevisionResult">
        select * from plan_revision where plan_id = #{planId} order by version desc
    </select>

    <select id="selectMaxVersionByPlanId" parameterType="Long" resultType="int">
        select IFNULL(MAX(version), 0) from plan_revision where plan_id = #{planId}
    </select>

    <insert id="insertPlanRevision" parameterType="PlanRevision" useGeneratedKeys="true" keyProperty="id">
        insert into plan_revision (plan_id, version, changes, submitter_note, create_by, create_time)
        values (#{planId}, #{version}, #{changes}, #{submitterNote}, #{createBy}, sysdate())
    </insert>

</mapper>
